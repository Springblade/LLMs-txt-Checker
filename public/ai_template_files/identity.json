{
  "$schema": "https://www.365i.co.uk/ai-visibility-definition/specifications/identity-json/identity-json.schema.json",

  "name": "[Your Official Registered Business Name]",
  "legalName": "[Your Legal Business Name Ltd]",
  "alternateName": [
    "[Your Trading Name]",
    "[Your Brand Name]"
  ],
  "url": "https://www.yourwebsite.com/",
  "type": "[Organization type: Corporation, LocalBusiness, ProfessionalService, etc.]",
  "description": "[Factual 1-3 sentence description of your business. What you do, who you serve.]",

  "foundingDate": "[YYYY-MM-DD]",
  "foundingLocation": {
    "name": "[City]",
    "addressCountry": "[GB]"
  },

  "headquarters": {
    "streetAddress": "[Street Address]",
    "addressLocality": "[City]",
    "postalCode": "[Postcode]",
    "addressCountry": "[GB]"
  },

  "locations": [
    {
      "name": "[Office Name (Headquarters)]",
      "streetAddress": "[Street Address]",
      "addressLocality": "[City]",
      "postalCode": "[Postcode]",
      "addressCountry": "[GB]",
      "isHeadquarters": true
    }
  ],

  "areaServed": [
    {
      "type": "Country",
      "name": "[United Kingdom]",
      "code": "[GB]"
    }
  ],

  "contactPoints": [
    {
      "type": "GeneralEnquiries",
      "email": "[hello@yourwebsite.com]",
      "telephone": "[+44 XXXX XXXXXX]"
    },
    {
      "type": "Support",
      "email": "[support@yourwebsite.com]"
    }
  ],

  "services": [
    "[Service 1 description]",
    "[Service 2 description]",
    "[Service 3 description]"
  ],

  "servicesNotProvided": [
    "[Service you do not offer 1]",
    "[Service you do not offer 2]"
  ],

  "industry": "[Your Primary Industry/Sector]",
  "naicsCode": "[NAICS code if applicable]",

  "numberOfEmployees": {
    "minValue": "[minimum]",
    "maxValue": "[maximum]"
  },

  "identifier": [
    {
      "type": "CompanyRegistration",
      "value": "[Company number]",
      "jurisdiction": "[GB]"
    },
    {
      "type": "VAT",
      "value": "[VAT number]",
      "jurisdiction": "[GB]"
    }
  ],

  "sameAs": [
    "[https://www.linkedin.com/company/your-company]",
    "[https://twitter.com/yourcompany]"
  ],

  "founder": {
    "name": "[Founder Name]",
    "jobTitle": "[Founder Title]"
  },

  "metadata": {
    "lastUpdated": "[YYYY-MM-DD]",
    "specificationVersion": "1.0.0"
  },

  "_specification": {
    "name": "identity.json (ADF-006)",
    "version": "1.1.1",
    "url": "https://www.ai-visibility.org.uk/specifications/identity-json/"
  }
}

